-- ============================================
-- SISTEMA DE PUXAR ITENS (MAGNET GRAB)
-- ============================================
local MagnetGrab = {
    IsGrabbing = false,
    CurrentTarget = nil,
    Remotes = nil
}

function MagnetGrab:FindTarget()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local nearest = nil
    local nearestDist = CONFIG.GrabRadius
    
    -- Procurar por partes com atributos específicos
    for _, part in pairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") and (part:GetAttribute("IsGrabbable") or part:GetAttribute("IsMoney")) then
            local distance = (part.Position - rootPart.Position).Magnitude
            
            if distance <= CONFIG.GrabRadius and distance < nearestDist then
                local screenPoint = camera:WorldToScreenPoint(part.Position)
                if screenPoint and screenPoint.Z > 0 then
                    local targetPos = Vector2.new(screenPoint.X, screenPoint.Y)
                    local mousePos = Vector2.new(mouse.X, mouse.Y)
                    
                    if (targetPos - mousePos).Magnitude <= 100 then
                        nearestDist = distance
                        nearest = part
                    end
                end
            end
        end
    end
    
    return nearest
end

function MagnetGrab:Grab(target)
    if self.IsGrabbing or not target then return false end
    
    self.IsGrabbing = true
    self.CurrentTarget = target
    
    -- Mostrar UI de progresso
    ui.MagnetFrame.Visible = true
    ui.ProgressFill.Size = UDim2.new(0, 0, 1, 0)
    
    -- Animar barra
    local tween = TweenService:Create(ui.ProgressFill,
        TweenInfo.new(CONFIG.GrabTime, Enum.EasingStyle.Linear),
        {Size = UDim2.new(1, 0, 1, 0)}
    )
    tween:Play()
    
    -- Efeito visual no alvo
    local originalColor = target.Color
    target.Color = CONFIG.NeonColor
    
    -- Simular progresso
    local startTime = tick()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    repeat
        task.wait()
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / CONFIG.GrabTime, 1)
        
        ui.ProgressText.Text = string.format("PUXANDO... %.0f%%", progress * 100)
        
        -- Puxar gradualmente
        if target and target.Parent and rootPart then
            local direction = (rootPart.Position - target.Position).Unit
            target.Position = target.Position + direction * CONFIG.PullSpeed * (progress + 0.3)
        end
        
        if rootPart and target and (target.Position - rootPart.Position).Magnitude > CONFIG.GrabRadius + 5 then
            break
        end
        
    until elapsed >= CONFIG.GrabTime or not target or not target.Parent
    
    tween:Cancel()
    ui.MagnetFrame.Visible = false
    
    -- Chamar remote do servidor para coletar
    if target and target.Parent then
        local isMoney = target:GetAttribute("IsMoney")
        local value = target:GetAttribute("Value") or 50
        
        -- Simular coleta (em produção, chamar RemoteFunction)
        local currentMoney = tonumber(ui.MoneyText.Text) or 0
        local newMoney = currentMoney + value
        ui.MoneyText.Text = tostring(newMoney)
        
        if isMoney then
            ShowNotification(ui.NotificationContainer, "💰 DINHEIRO", string.format("+$%d", value), CONFIG.NeonGreen)
        else
            local itemName = target:GetAttribute("ItemName") or "Item"
            ShowNotification(ui.NotificationContainer, "📦 ITEM", string.format("+%s", itemName), CONFIG.NeonPink)
        end
        
        target:Destroy()
    end
    
    if target then
        target.Color = originalColor
    end
    
    self.IsGrabbing = false
    self.CurrentTarget = nil
    
    return true
end

