-- ============================================
-- CRIAR REMOTES (SE NÃO EXISTIREM)
-- ============================================
local function SetupRemotes()
    local remotesFolder = ReplicatedStorage:FindFirstChild("PrecisionRemotes")
    if not remotesFolder then
        remotesFolder = Instance.new("Folder")
        remotesFolder.Name = "PrecisionRemotes"
        remotesFolder.Parent = ReplicatedStorage
    end
    
    -- Remote para puxar itens
    local grabRemote = remotesFolder:FindFirstChild("GrabItem")
    if not grabRemote then
        grabRemote = Instance.new("RemoteFunction")
        grabRemote.Name = "GrabItem"
        grabRemote.Parent = remotesFolder
    end
    
    -- Remote para pegar dinheiro
    local moneyRemote = remotesFolder:FindFirstChild("CollectMoney")
    if not moneyRemote then
        moneyRemote = Instance.new("RemoteFunction")
        moneyRemote.Name = "CollectMoney"
        moneyRemote.Parent = remotesFolder
    end
    
    return {GrabItem = grabRemote, CollectMoney = moneyRemote}
end

