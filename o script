    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notif
    
    local msgLabel = Instance.new("TextLabel")
    msgLabel.Size = UDim2.new(1, -10, 0, 22)
    msgLabel.Position = UDim2.new(0.02, 0, 0.5, 0)
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    msgLabel.TextSize = 12
    msgLabel.Font = Enum.Font.Gotham
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.Parent = notif
    
    -- Animação de entrada
    notif.BackgroundTransparency = 1
    notif.Position = UDim2.new(0, 0, 1, 20)
    
    local enterTween = TweenService:Create(notif,
        TweenInfo.new(0.3, Enum.EasingStyle.Back),
        {BackgroundTransparency = 0.2, Position = UDim2.new(0, 0, 1, 0)}
    )
    enterTween:Play()
    
    -- Auto destruir
    task.wait(3.5)
    
    local exitTween = TweenService:Create(notif,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad),
        {BackgroundTransparency = 1, Position = UDim2.new(0, 0, 1, 20)}
    )
    exitTween:Play()
    exitTween.Completed:Wait()
    notif:Destroy()
    
    -- Reposicionar notificações
    for _, n in pairs(container:GetChildren()) do
        local newPos = n.Position.Y.Offset - 55
        TweenService:Create(n, TweenInfo.new(0.2), {Position = UDim2.new(0, 0, 1, newPos)}):Play()
    end
end

-- ============================================
-- AIM ASSIST (VISUAL APENAS - SEGURO)
-- ============================================
local AimAssist = {
    IsActive = false,
    CurrentTarget = nil
}

function AimAssist:FindTarget()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local bestTarget = nil
    local bestScore = 0
    local mousePos = Vector2.new(mouse.X, mouse.Y)
    
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            local targetChar = targetPlayer.Character
            local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
            local humanoid = targetChar and targetChar:FindFirstChild("Humanoid")
            
            if targetHRP and humanoid and humanoid.Health > 0 then
                local distance = (targetHRP.Position - rootPart.Position).Magnitude
                
                if distance <= CONFIG.MaxAimDistance then
                    local screenPoint = camera:WorldToScreenPoint(targetHRP.Position)
                    
                    if screenPoint.Z > 0 then
                        local targetPos = Vector2.new(screenPoint.X, screenPoint.Y)
                        local angleDist = (targetPos - mousePos).Magnitude
                        
                        if angleDist <= CONFIG.AimRadius then
                            local score = (CONFIG.AimRadius - angleDist) * 10
                            score = score - (distance * 0.5)
                            
                            if angleDist <= CONFIG.MagnetRadius then
                                score = score + 50
                            end
                            
                            if score > bestScore then
                                bestScore = score
                                bestTarget = targetChar
                            end
                        end
                    end
                end
            end
        end
    end
    
    return bestTarget
end

