-- ============================================
-- INPUT E LOOP PRINCIPAL
-- ============================================
local ui
local remotes

-- Inicialização
local function Init()
    print("🎯 Iniciando Sistema de Precisão...")
    
    ui = CreateUI()
    
    -- Setup remotes
    remotes = SetupRemotes()
    
    -- Inicializar dinheiro
    MoneyManager.Balance = CONFIG.StartingMoney
    MoneyManager:UpdateDisplay(ui.MoneyText)
    
    -- Criar itens de teste
    task.wait(0.5)
    CreateTestItems()
    
    -- Mostrar tutorial
    ShowNotification(ui.NotificationContainer, "🎮 SISTEMA PRONTO!", 
        "Aponte para itens e pressione F para coletar", CONFIG.NeonColor)
    
    -- Input para coletar (tecla F)
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.F then
            local target = MagnetGrab:FindTarget()
            
            if target then
                -- Mostrar indicador
                local screenPos = camera:WorldToScreenPoint(target.Position)
                if screenPos and screenPos.Z > 0 then
                    ui.TargetIndicator.Visible = true
                    ui.TargetIndicator.Position = UDim2.new(0, screenPos.X - 35, 0, screenPos.Y - 35)
                    task.wait(0.15)
                    ui.TargetIndicator.Visible = false
                end
                
                MagnetGrab:Grab(target)
            else
                -- Feedback visual sem alvo
                ui.CenterDot.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                task.wait(0.1)
                ui.CenterDot.BackgroundColor3 = CONFIG.NeonColor
            end
        end
    end)
    
    -- Efeito de clique
    mouse.Button1Down:Connect(function()
        -- Efeito de recuo na mira
        local originalSize = ui.CrosshairContainer.Size
        local shrinkTween = TweenService:Create(ui.CrosshairContainer,
            TweenInfo.new(0.05, Enum.EasingStyle.Quad),
            {Size = UDim2.new(0, 90, 0, 90)}
        )
        shrinkTween:Play()
        shrinkTween.Completed:Wait()
        
        TweenService:Create(ui.CrosshairContainer,
            TweenInfo.new(0.1, Enum.EasingStyle.Back),
            {Size = originalSize}
        ):Play()
        
        -- Hit effect se tiver alvo
        if AimAssist.CurrentTarget then
            ui.CenterDot.BackgroundColor3 = CONFIG.NeonPink
            task.wait(0.08)
            ui.CenterDot.BackgroundColor3 = CONFIG.NeonColor
        end
    end)
    
    print("✅ Sistema rodando!")
end

