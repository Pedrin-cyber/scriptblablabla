}

function MoneyManager:UpdateDisplay(uiElement)
    uiElement.Text = tostring(self.Balance)
    
    -- Efeito visual
    local originalColor = uiElement.TextColor3
    uiElement.TextColor3 = CONFIG.NeonGreen
    task.wait(0.15)
    uiElement.TextColor3 = originalColor
end

function MoneyManager:AddMoney(amount, uiElement)
    self.Balance = self.Balance + amount
    self:UpdateDisplay(uiElement)
    return self.Balance
end

